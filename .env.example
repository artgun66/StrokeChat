# Copy to .env.local for local development. Never commit .env.local.

# --- Backend ---
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=dev-only-not-for-prod-please-generate-a-real-one
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Postgres (matches docker-compose.local.yml)
DATABASE_URL=postgres://local_llm:local_llm@postgres:5432/local_llm

# Storage abstraction (FileSystemStorage now, GCSStorage later)
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
DATA_DIR=/app/data

# Symmetric crypto (Fernet now, KMS later). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Catalog manifest signing (Ed25519). Generate with:
#   docker compose -f docker-compose.local.yml run --rm backend python manage.py rotate_catalog_keys
CATALOG_SIGNING_PRIVATE_KEY=
CATALOG_SIGNING_PUBLIC_KEY=

# Auth profile: control_plane (signup + multi-tenant) | runtime (single tenant) | baremetal
AUTH_PROFILE=control_plane

# --- Frontend ---
# Direct in dev; in production this is a Cloud Run host
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://backend:8000
