{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StrokeChat",
  "version": "0.1.0",
  "identifier": "com.strokechat.app",
  "build": {
    "frontendDist": "splash"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StrokeChat",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../staged/": "staged/"
    },
    "macOS": {
      "entitlements": "../build/entitlements.mac.plist",
      "signingIdentity": "-"
    }
  }
}
