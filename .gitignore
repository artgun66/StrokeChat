# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
.env
.env.local
.env.*.local
.python-version-local
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Node
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
.pnpm-store/

# Editors / per-developer tooling
.vscode/
.idea/
.claude/
*.swp
*.swo
.DS_Store

# Project data dirs (model files, downloads, runtime state).
# Anchored with leading `/` so this only matches the top-level data dirs and
# does NOT swallow legitimate `data/` subdirectories like
# backend/apps/catalog/data/ (catalog seed YAMLs).
/data/
/backend/data/

# Secrets
*.pem
*.key
secrets/

# Build artifacts
*.log

# Large model files / local-only data
/artun_model/BiomedParse/
/artun_model/move_to_linux/
/artun_model/outputs/

# Desktop app (Tauri)
/desktop/node_modules/
/desktop/dist/
# Keep the staged/ dir (Tauri validates the resource path at compile time) but ignore its
# heavy generated contents.
/desktop/staged/*
!/desktop/staged/.gitkeep
/desktop/src-tauri/target/
/desktop/src-tauri/gen/
# Bundled weights are fetched at stage time, never committed (multi-GB).
/desktop/resources/models/*.gguf
/desktop/resources/models/*.ckpt
# Re-include desktop/build/ (the global `build/` rule above would swallow the
# electron-builder resources we DO need tracked, e.g. entitlements).
!/desktop/build/
!/desktop/build/**
.vercel
.env*

# Large GPU model weights — live on Modal, not tracked in git
vessel_weights/
